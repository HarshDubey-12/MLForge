# Application
APP_NAME=ml_research_assistant
APP_ENV=development
LOG_LEVEL=INFO

# Models
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
GENERATOR_MODEL=your-fine-tuned-model
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Storage
SQLITE_PATH=./ml_research_assistant.db
FAISS_INDEX_PATH=./artifacts/faiss/index.bin
METADATA_PATH=./artifacts/faiss/metadata.json

# API
API_HOST=0.0.0.0
API_PORT=8000

